---
import StoreBadges from './StoreBadges.astro';
const heroImg = '/images/hero-basketball.jpg';
---
<section class="hero" style={`background-image:linear-gradient(120deg, rgba(6,70,106,.96), rgba(0,0,0,.86)), url('${heroImg}')`}>
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-content">
    <p class="eyebrow text-accent h-enter h-1">Join the movement</p>
    <h1 class="display hero-title h-enter h-2">Revolutionizing sports education for <span class="text-accent">the next generation.</span></h1>
    <p class="hero-sub h-enter h-3">Upload a clip. Get personalized feedback from a verified coach. Level up — anywhere.</p>
    <div class="h-enter h-4">
      <StoreBadges source="hero" />
    </div>
  </div>
</section>
<style>
  .hero {
    position: relative;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(700px 400px at 30% 60%, rgba(8,180,182,.12), transparent 65%),
      radial-gradient(500px 300px at 70% 30%, rgba(243,94,10,.07), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding: 108px 0 96px;
    max-width: 800px;
  }
  .hero-title {
    font-size: clamp(44px, 8vw, 88px);
    margin: 12px 0 20px;
    line-height: .93;
  }
  .hero-sub {
    font-size: 19px;
    color: rgba(255,255,255,.84);
    max-width: 560px;
    margin-bottom: 28px;
    line-height: 1.55;
  }

  /* ── staggered entrance keyframe ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: none; }
  }
  .h-enter {
    animation: fadeUp .7s cubic-bezier(.16,1,.3,1) both;
  }
  .h-1 { animation-delay: .05s; }
  .h-2 { animation-delay: .15s; }
  .h-3 { animation-delay: .28s; }
  .h-4 { animation-delay: .42s; }

  @media (prefers-reduced-motion: reduce) {
    .h-enter { animation: none; opacity: 1; transform: none; }
  }
</style>
