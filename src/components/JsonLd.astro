---
interface Props { schema: Record<string, unknown> }
const { schema } = Astro.props;
// Schemas are always code-constructed (trusted), but escape any literal "</script>"
// in string values so a stray value can never break out of the script element.
const json = JSON.stringify(schema).replace(/<\/script>/gi, '<\\/script>');
---
<script type="application/ld+json" set:html={json} is:inline />
