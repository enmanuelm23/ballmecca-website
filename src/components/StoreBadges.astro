---
import { site } from '../data/site';
interface Props { source: string }
const { source } = Astro.props;
---
<div class="store-badges">
  <a class="badge" href={site.appStoreUrl} target="_blank" rel="noopener"
     aria-label="Download on the App Store"
     data-event="store_click" data-store="app_store" data-source={source}>
    <span class="badge-glyph" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
    </span>
    <span class="badge-text">
      <span class="badge-sub">Download on the</span><span class="badge-main">App Store</span>
    </span>
  </a>
  <a class="badge" href={site.playStoreUrl} target="_blank" rel="noopener"
     aria-label="Get it on Google Play"
     data-event="store_click" data-store="google_play" data-source={source}>
    <span class="badge-glyph" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true"><path d="M3.18 23.76c.37.2.8.2 1.19-.01l12.1-6.99-2.61-2.61-10.68 9.61zm-1.1-20.1A1.7 1.7 0 0 0 2 4.5v15c0 .55.25 1.04.65 1.37l.08.06 8.41-8.41v-.2L2.08 3.66zm18.63 8.47-2.58-1.49-2.9 2.9 2.9 2.9 2.59-1.5c.74-.43.74-1.38-.01-1.81zM4.37.49c-.38-.22-.82-.22-1.2.01L13.5 11.63l-2.61-2.61L4.37.49z"/></svg>
    </span>
    <span class="badge-text">
      <span class="badge-sub">GET IT ON</span><span class="badge-main">Google Play</span>
    </span>
  </a>
</div>
<style>
  .store-badges { display:flex; gap:12px; flex-wrap:wrap; }
  .badge { display:flex; align-items:center; gap:10px; background:#000;
    border:1px solid rgba(255,255,255,.25); color:#fff; border-radius:var(--radius-sm);
    padding:8px 16px; min-height:48px; box-sizing:border-box; transition:background .15s ease, border-color .15s ease; }
  .badge:hover { text-decoration:none; background:#1a1a1a; border-color:rgba(255,255,255,.5); }
  .badge-glyph { display:flex; align-items:center; color:#fff; }
  .badge-text { display:flex; flex-direction:column; line-height:1.1; }
  .badge-sub { font-size:10px; text-transform:uppercase; letter-spacing:.04em; color:#fff; }
  .badge-main { font-size:18px; font-weight:700; color:#fff; }
</style>
