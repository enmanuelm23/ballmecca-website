---
import BaseLayout from '../layouts/BaseLayout.astro';
const values = [
  { h: 'Wisdom', p: 'Learning from experience, mentors, and the game itself.' },
  { h: 'Cura Personalis', p: 'Latin for "care for the whole person." We believe in nurturing athletes not just as players, but as people.' },
  { h: 'Discipline', p: 'Building habits that lead to excellence, on the field and in the office.' },
  { h: 'Access', p: 'No athlete should be limited by their zip code. Elite coaching belongs to everyone.' },
];
const team = [
  { name: 'Manny Madera', role: 'CEO', bio: 'Founder and visionary behind Ballmecca. Passionate about using technology to democratize access to elite coaching for youth athletes everywhere.' },
  { name: 'Amelia Arabe', role: 'CXIO', bio: 'Leading community experience and operations. A cellist and multi-sport athlete who believes that excellence in sport and in life go hand in hand.' },
];
const partners = [
  { logo: 'LPF', name: 'Leveling the Playing Field', p: 'LPF tackles the growing challenge of the "pay-to-play" model in athletics. They are a non-profit ensuring access to equipment and opportunity for underserved youth.' },
  { logo: 'LOYOLA MD', name: 'Loyola University Maryland', p: 'Ballmecca was born in Baltimore, Maryland. We thrived thanks to numerous organizations and individuals at Loyola Maryland, including the Baltiprenuers Accelerator Program, the Engineering Department, Loyola Consulting Group, and Loyola Athletics.' },
];
---
<BaseLayout title="About Us" description="Ballmecca's mission: with the right guidance, anyone can achieve greatness. Born in Baltimore out of Loyola University Maryland." path="/about">
  <section class="container about-hero">
    <p class="eyebrow text-accent">Our story</p>
    <h1 class="display about-hero-title">We believe anyone can achieve greatness.</h1>
    <p class="about-prose text-muted">We are a diverse team of engineers, athletes, and educators who believe in the power of Education, Quality Feedback, and Tech for Good.</p>
  </section>

  <section class="container about-section">
    <p class="eyebrow text-warm">Our mission</p>
    <h2 class="display about-h">Leveling the playing field.</h2>
    <div class="about-prose">
      <p class="text-muted">We believe that with the right guidance and feedback, anyone can achieve greatness. Our platform provides access to top-tier coaching, character-building opportunities, and pathways to success.</p>
      <p class="text-muted">We exist to support underserved youth through the power of sports. Too often, access to quality coaching and support is limited by zip code or income. Ballmecca is leveling the playing field — giving every kid a shot at greatness.</p>
      <p class="text-muted">Through passion, mentorship, and accountability, we create lasting impact beyond the game.</p>
    </div>
  </section>

  <section class="container about-section">
    <p class="eyebrow text-warm">What we stand for</p>
    <h2 class="display about-h">Our core values.</h2>
    <p class="text-muted">Guiding principles for growth on and off the court.</p>
    <div class="about-grid">
      {values.map((v) => (
        <div class="about-card">
          <h3>{v.h}</h3><p class="text-muted">{v.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container about-section">
    <p class="eyebrow text-accent">The people behind it</p>
    <h2 class="display about-h">Meet the team.</h2>
    <p class="text-muted">Our team approaches software engineering with the same values that make the game a lifelong pursuit of growth.</p>
    <div class="about-grid">
      {team.map((t) => (
        <div class="about-card">
          <div class="about-role text-accent">{t.role}</div>
          <h3 class="about-name">{t.name}</h3>
          <p class="text-muted">{t.bio}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="container about-section about-section-last">
    <p class="eyebrow text-warm">Partnerships that power us</p>
    <h2 class="display about-h">Our impact is amplified through partnerships aligned with our vision.</h2>
    <div class="about-grid">
      {partners.map((p) => (
        <div class="about-card">
          <div class="display text-accent about-logo">{p.logo}</div>
          <h3 class="about-name">{p.name}</h3>
          <p class="text-muted">{p.p}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .about-hero { padding:64px 0 24px; }
  .about-hero-title { font-size:clamp(34px,6vw,52px); }
  .about-section { padding:24px 0 48px; }
  .about-section-last { padding-bottom:80px; }
  .about-h { font-size:clamp(26px,4vw,34px); max-width:760px; }
  .about-prose { max-width:720px; }
  .about-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:20px; margin-top:20px; }
  .about-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius-md); padding:24px; }
  .about-role { font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:1px; }
  .about-name { margin:4px 0 8px; }
  .about-logo { font-size:24px; margin-bottom:8px; }
  @media (max-width:640px){ .about-grid{ grid-template-columns:1fr; } }
</style>
